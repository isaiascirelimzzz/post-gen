{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@prisma/client": [
        "../node_modules/@prisma/client"
      ]
    }
  },
  "include": [
    "src/**/*",
    "prisma.config.ts",
    "prisma/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}